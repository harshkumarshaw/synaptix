# Synaptix Environment Variables Template
# Copy to .env and fill in actual values. NEVER commit .env to git.

# ============================================================================
# Application
# ============================================================================
SNX_ENV=local                              # local | staging | production
SNX_LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR
SNX_TIMEZONE=Asia/Kolkata

# ============================================================================
# Database (Local Dev — Tier 0)
# ============================================================================
SNX_DATABASE_URL=postgresql+asyncpg://snx:snx_dev_pass@localhost:5432/synaptix_dev
SNX_DATABASE_URL_TEST=postgresql+asyncpg://snx_test:snx_test_pass@localhost:5433/synaptix_test
SNX_DATABASE_POOL_SIZE=10
SNX_DATABASE_MAX_OVERFLOW=20

# ============================================================================
# Database (Cloud — Tier 1+, configure when deploying)
# ============================================================================
# SNX_CLOUD_SQL_INSTANCE=project-id:region:instance-name
# SNX_CLOUD_SQL_DB=synaptix
# SNX_CLOUD_SQL_USER=snx_prod
# SNX_CLOUD_SQL_PASSWORD=  # from Google Secret Manager in production

# ============================================================================
# Authentication
# ============================================================================
SNX_JWT_SECRET=change_me_use_secure_random_string_minimum_32_chars
SNX_JWT_ALGORITHM=HS256
SNX_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
SNX_JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
SNX_MFA_ISSUER=Synaptix

# OAuth (configure when ready)
SNX_GOOGLE_CLIENT_ID=
SNX_GOOGLE_CLIENT_SECRET=
SNX_MICROSOFT_CLIENT_ID=
SNX_MICROSOFT_CLIENT_SECRET=

# ============================================================================
# AI APIs (configure when ready)
# ============================================================================
ANTHROPIC_API_KEY=                         # Claude Sonnet 4.6 (primary)
GOOGLE_GENERATIVE_AI_API_KEY=              # Gemini 3.5 Flash (fallback)
SNX_AI_PRIMARY_MODEL=claude-sonnet-4-6
SNX_AI_FALLBACK_MODEL=gemini-3-5-flash
SNX_AI_RATE_LIMIT_PER_USER=30              # AI requests per minute per user

# ============================================================================
# Notifications (configure when ready)
# ============================================================================
SNX_SMS_PROVIDER=                          # textlocal | gupshup | msg91
SNX_SMS_API_KEY=
SNX_SMS_SENDER_ID=NRMALA                   # TRAI-registered sender ID

SNX_WHATSAPP_PROVIDER=                     # gupshup | twilio | meta
SNX_WHATSAPP_API_KEY=
SNX_WHATSAPP_PHONE_NUMBER_ID=

SNX_EMAIL_PROVIDER=smtp                    # smtp | sendgrid | ses
SNX_SMTP_HOST=localhost                    # mailhog for local dev
SNX_SMTP_PORT=1025
SNX_SMTP_USER=
SNX_SMTP_PASSWORD=
SNX_EMAIL_FROM=noreply@synaptix.local

# ============================================================================
# Storage (configure when ready)
# ============================================================================
SNX_STORAGE_BACKEND=local                  # local | gcs | s3
SNX_STORAGE_LOCAL_PATH=./storage           # local dev
SNX_GCS_BUCKET_PREFIX=synaptix-            # production
SNX_GCP_PROJECT_ID=

# ============================================================================
# Tenant Settings
# ============================================================================
SNX_DEFAULT_TENANT_ID=                     # for single-tenant local dev
SNX_TENANT_HEADER=X-Tenant-ID

# ============================================================================
# Mobile App
# ============================================================================
SNX_API_BASE_URL_MOBILE=http://localhost:8000   # local
# SNX_API_BASE_URL_MOBILE=https://api.synaptix.example.com  # production

# ============================================================================
# DPDP Act 2023 Compliance
# ============================================================================
SNX_DPO_EMAIL=                             # required before production
SNX_DPO_NAME=                              # required before production
SNX_BREACH_NOTIFICATION_RECIPIENTS=        # comma-separated emails
SNX_DATA_RESIDENCY_REGION=asia-south1     # India only

# ============================================================================
# Observability
# ============================================================================
SNX_OTEL_ENABLED=false                     # set true when monitoring set up
SNX_OTEL_ENDPOINT=
SNX_SENTRY_DSN=

# ============================================================================
# Feature Flags
# ============================================================================
SNX_FEATURE_WHATSAPP_BOT=false
SNX_FEATURE_AI_ASSISTANT=false
SNX_FEATURE_PREDICTIVE_ANALYTICS=false
